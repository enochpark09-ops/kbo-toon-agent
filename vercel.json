{
  "version": 2,
  "builds": [
    { "src": "api/generate.py", "use": "@vercel/python" },
    { "src": "public/**",       "use": "@vercel/static" },
    { "src": "index.html",      "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/generate", "dest": "api/generate.py" },
    { "src": "/asset/(.*)",   "dest": "public/asset/$1"  },
    { "src": "/output/(.*)",  "dest": "public/output/$1" },
    { "src": "/(.*)",         "dest": "index.html"       }
  ]
}
